{
  "expo": {
    "name": "ExpenseFlow",
    "slug": "expenseflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#22c55e"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.expenseflow"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#22c55e"
      },
      "package": "app.expenseflow"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        { "icon": "./assets/notification-icon.png", "color": "#22c55e" }
      ]
    ],
    "scheme": "expenseflow",
    "extra": {
      "eas": { "projectId": "YOUR_EAS_PROJECT_ID" },
      "apiUrl": "http://localhost:3001/api/v1"
    }
  }
}
