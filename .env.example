# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/expenseflow

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-random-secret-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-random-secret
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Apple Sign In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=expenseflow
S3_REGION=us-east-1

# OCR Provider: openai | google | azure
OCR_PROVIDER=openai
OPENAI_API_KEY=
GOOGLE_VISION_API_KEY=
AZURE_FORM_RECOGNIZER_ENDPOINT=
AZURE_FORM_RECOGNIZER_KEY=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@expenseflow.app

# Exchange Rates
EXCHANGE_RATE_API_KEY=

# Public URLs
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002

# Admin
ADMIN_EMAIL=admin@expenseflow.app
ADMIN_PASSWORD=Admin@12345

# App
NODE_ENV=development
PORT=3001
