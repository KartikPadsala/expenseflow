generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum GroupType {
  HOME
  TRIP
  COUPLE
  OFFICE
  OTHER
}

enum GroupMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum SplitMethod {
  EQUAL
  UNEQUAL
  PERCENTAGE
  SHARES
  EXACT
  MULTI_PAYER
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  PAYPAL
  STRIPE
  WISE
  INTERAC
  OTHER
}

enum SettlementStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum NotificationType {
  EXPENSE_ADDED
  EXPENSE_EDITED
  EXPENSE_DELETED
  GROUP_INVITE
  GROUP_JOINED
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  SETTLEMENT_REQUEST
  SETTLEMENT_COMPLETED
  REMINDER
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  username          String    @unique
  displayName       String
  avatarUrl         String?
  passwordHash      String?
  googleId          String?   @unique
  appleId           String?   @unique
  role              UserRole  @default(USER)
  isEmailVerified   Boolean   @default(false)
  isActive          Boolean   @default(true)
  defaultCurrency   String    @default("USD")
  language          String    @default("en")
  timezone          String    @default("UTC")
  pushTokens        String[]
  emailVerifyToken  String?
  passwordResetToken String?
  passwordResetExpiry DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // relations
  sentFriendships      Friendship[]         @relation("Requester")
  receivedFriendships  Friendship[]         @relation("Addressee")
  ownedGroups          Group[]              @relation("GroupCreator")
  groupMemberships     GroupMember[]
  paidExpenses         Expense[]            @relation("ExpensePaidBy")
  createdExpenses      Expense[]            @relation("ExpenseCreatedBy")
  expenseParticipations ExpenseParticipant[]
  sentSettlements      Settlement[]         @relation("SettlementPayer")
  receivedSettlements  Settlement[]         @relation("SettlementPayee")
  notifications        Notification[]
  uploadedAttachments  Attachment[]
  customCategories     Category[]
  recurringExpenses    RecurringExpense[]
  auditLogs            AuditLog[]

  @@index([email])
  @@index([username])
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  inviteToken String?          @unique
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("Addressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
  @@index([status])
}

model Group {
  id          String    @id @default(cuid())
  name        String
  description String?
  avatarUrl   String?
  type        GroupType @default(OTHER)
  currency    String    @default("USD")
  isArchived  Boolean   @default(false)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy       User              @relation("GroupCreator", fields: [createdById], references: [id])
  members         GroupMember[]
  expenses        Expense[]
  settlements     Settlement[]
  recurringExpenses RecurringExpense[]

  @@index([createdById])
}

model GroupMember {
  id       String          @id @default(cuid())
  groupId  String
  userId   String
  role     GroupMemberRole @default(MEMBER)
  joinedAt DateTime        @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
}

model Expense {
  id              String      @id @default(cuid())
  groupId         String?
  description     String
  amount          Decimal     @db.Decimal(12, 2)
  currency        String      @default("USD")
  convertedAmount Decimal?    @db.Decimal(12, 2)
  baseCurrency    String?
  exchangeRate    Decimal?    @db.Decimal(10, 6)
  date            DateTime
  categoryId      String?
  paidById        String
  splitMethod     SplitMethod @default(EQUAL)
  notes           String?
  isDeleted       Boolean     @default(false)
  isRecurring     Boolean     @default(false)
  recurringId     String?
  createdById     String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  group           Group?               @relation(fields: [groupId], references: [id])
  category        Category?            @relation(fields: [categoryId], references: [id])
  paidBy          User                 @relation("ExpensePaidBy", fields: [paidById], references: [id])
  createdBy       User                 @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
  recurring       RecurringExpense?    @relation(fields: [recurringId], references: [id])
  participants    ExpenseParticipant[]
  items           ExpenseItem[]
  attachments     Attachment[]

  @@index([groupId])
  @@index([paidById])
  @@index([date])
  @@index([categoryId])
  @@index([isDeleted])
}

model ExpenseParticipant {
  id           String  @id @default(cuid())
  expenseId    String
  userId       String
  owedAmount   Decimal @db.Decimal(12, 2)
  paidAmount   Decimal @db.Decimal(12, 2) @default(0)
  isSettled    Boolean @default(false)
  sharePercent Decimal? @db.Decimal(5, 2)
  shares       Int?

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
  @@index([userId])
}

model ExpenseItem {
  id          String  @id @default(cuid())
  expenseId   String
  description String
  amount      Decimal @db.Decimal(12, 2)
  quantity    Int     @default(1)

  expense      Expense               @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  participants ExpenseItemParticipant[]
}

model ExpenseItemParticipant {
  id        String @id @default(cuid())
  itemId    String
  userId    String
  amount    Decimal @db.Decimal(12, 2)

  item ExpenseItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, userId])
}

model Settlement {
  id        String           @id @default(cuid())
  groupId   String?
  payerId   String
  payeeId   String
  amount    Decimal          @db.Decimal(12, 2)
  currency  String           @default("USD")
  method    PaymentMethod    @default(CASH)
  status    SettlementStatus @default(PENDING)
  notes     String?
  createdAt DateTime         @default(now())
  settledAt DateTime?

  group Group?  @relation(fields: [groupId], references: [id])
  payer User   @relation("SettlementPayer", fields: [payerId], references: [id])
  payee User   @relation("SettlementPayee", fields: [payeeId], references: [id])

  @@index([payerId])
  @@index([payeeId])
  @@index([groupId])
}

model RecurringExpense {
  id          String             @id @default(cuid())
  groupId     String?
  description String
  amount      Decimal            @db.Decimal(12, 2)
  currency    String             @default("USD")
  frequency   RecurringFrequency @default(MONTHLY)
  splitMethod SplitMethod        @default(EQUAL)
  nextDueDate DateTime
  isActive    Boolean            @default(true)
  createdById String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  group     Group?    @relation(fields: [groupId], references: [id])
  createdBy User      @relation(fields: [createdById], references: [id])
  expenses  Expense[]
}

model Category {
  id        String  @id @default(cuid())
  name      String
  icon      String
  color     String
  isDefault Boolean @default(false)
  userId    String?

  user     User?     @relation(fields: [userId], references: [id])
  expenses Expense[]

  @@index([userId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model Attachment {
  id           String   @id @default(cuid())
  expenseId    String
  uploadedById String
  fileName     String
  fileSize     Int
  mimeType     String
  storageKey   String
  url          String?
  createdAt    DateTime @default(now())

  expense    Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation(fields: [uploadedById], references: [id])
}

model ExchangeRate {
  id           String   @id @default(cuid())
  fromCurrency String
  toCurrency   String
  rate         Decimal  @db.Decimal(10, 6)
  date         DateTime @db.Date
  source       String   @default("openexchangerates")

  @@unique([fromCurrency, toCurrency, date])
  @@index([fromCurrency, toCurrency, date])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
